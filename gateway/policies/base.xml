<!--
  Base policy for the Storyteller LLM API.
  - Routes to the Foundry Azure AI Model Inference backend.
  - Authenticates to the backend with the APIM system-assigned managed identity
    (account keys are disabled on foundry-acw, so MI is required).
  - Forces the api-version query parameter the inference endpoint expects.
-->
<policies>
    <inbound>
        <base />
        <set-backend-service backend-id="foundry-inference" />
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" />
        <set-query-parameter name="api-version" exists-action="override">
            <value>2024-05-01-preview</value>
        </set-query-parameter>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
