<!--
  Main Storyteller LLM API policy (path: /storyteller).
  Clean passthrough to Foundry via the shared backend fragment. AI gateway
  capabilities that are safe to run on every call (token metrics, semantic
  cache, content safety) are layered in here as their backing resources are
  provisioned. Token rate limiting lives on the dedicated /storyteller-throttled
  API so it doesn't interfere with the main fan-out demo.
-->
<policies>
    <inbound>
        <base />
        <include-fragment fragment-id="storyteller-backend" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
