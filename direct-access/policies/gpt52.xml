<!--
  General LLM model API (path: /gpt52) — direct-access lab.
  Access is restricted to callers whose Entra token carries the
  Model.General.Invoke app role (assigned to the AIG-General-LLM group and to
  authorized service principals). The API forces the model server-side to
  gpt-5.2.
-->
<policies>
    <inbound>
        <base />
        <validate-azure-ad-token tenant-id="{{aad-tenant-id}}" failed-validation-httpcode="403" failed-validation-error-message="Forbidden: your identity is not assigned the Model.General.Invoke role required for the general models.">
            <audiences>
                <audience>{{model-audience}}</audience>
            </audiences>
            <required-claims>
                <claim name="roles" match="any">
                    <value>Model.General.Invoke</value>
                </claim>
            </required-claims>
        </validate-azure-ad-token>
        <include-fragment fragment-id="direct-models-backend" />
        <set-body>@{
            JObject body = context.Request.Body.As&lt;JObject&gt;(true);
            body["model"] = "gpt-5.2";
            return body.ToString();
        }</set-body>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
