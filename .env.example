# Azure AI Foundry project configuration
# Copy this file to .env and fill in your specific values.

# Required
PROJECT_ENDPOINT=https://your-foundry-project.services.ai.azure.com/api/projects/your-project-name
MODEL_DEPLOYMENT_NAME=your-model-deployment-name

# Optional
AGENT_NAME=helpful-assistant
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_LOCATION=eastus2
AZURE_ENV_NAME=your-environment-name
AZURE_RESOURCE_GROUP=rg-foundry
# --- AI Gateway lab (gateway/) ---
# APIM gateway URL for the main storyteller API and the demo subscription key.
GATEWAY_BASE_URL=https://aig-acw.azure-api.net/storyteller
GATEWAY_SUBSCRIPTION_KEY=your-apim-subscription-key
# Log Analytics workspace customerId GUID (for logging_dashboard.py).
LOG_ANALYTICS_WORKSPACE_ID=your-log-analytics-workspace-guid
# --- Direct-access model RBAC lab (direct-access/) ---
# APIM gateway base (no path suffix; the demo appends /codex, /gpt52, /mistral).
DIRECT_GATEWAY_BASE_URL=https://aig-acw.azure-api.net
# Entra resource app that the caller token must target (audience) + tenant.
DIRECT_RESOURCE_APP_ID=your-direct-access-resource-app-id
DIRECT_TENANT_ID=your-tenant-id
# Product subscription keys (one per product/access bundle).
DIRECT_CODING_SUB_KEY=your-coding-assistants-subscription-key
DIRECT_GENERAL_SUB_KEY=your-general-llm-subscription-key
# Calling identity — persona-based flip.
# The demo picks a persona from the command line (access_matrix.py coding|general|user)
# so both service principals can live here at once and you never edit this file to
# switch. The "user" persona needs no creds (uses az login / DefaultAzureCredential).
DIRECT_CODING_CLIENT_ID=your-coding-client-app-id
DIRECT_CODING_CLIENT_SECRET=your-coding-client-secret
DIRECT_GENERAL_CLIENT_ID=your-general-client-app-id
DIRECT_GENERAL_CLIENT_SECRET=your-general-client-secret
# Legacy single-pair path (optional) — used only when no persona arg is passed.
# DIRECT_CLIENT_ID=your-client-app-id
# DIRECT_CLIENT_SECRET=your-client-secret

